<!DOCTYPE html>
<html class="">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - THEVENUE</title>

    <!-- Mitri: Bootstrap 3 + base libs -->
    <link rel="stylesheet" type="text/css" href="~/lib-public/libraries/lib.css">
    <link rel="stylesheet" type="text/css" href="~/lib-public/libraries/Stroke-Gap-Icon/stroke-gap-icon.css">

    <!-- Mitri: plugins, nav, slider -->
    <link rel="stylesheet" type="text/css" href="~/lib-public/css/plugins.css">
    <link rel="stylesheet" type="text/css" href="~/lib-public/css/navigation-menu.css">
    <link rel="stylesheet" type="text/css" href="~/lib-public/libraries/lightslider-master/lightslider.css">

    <!-- Mitri: theme -->
    <link rel="stylesheet" type="text/css" href="~/lib-public/style.css">
    <link rel="stylesheet" type="text/css" href="~/lib-public/css/shortcode.css">

    <!-- THEVENUE overrides -->
    <style>
        /* Brand colour overrides — gold accent on Mitri's dark palette */
        :root {
            --tv-gold:   #c9a96e;
            --tv-navy:   #1a1a2e;
            --tv-cream:  #f5f0e8;
        }
        .top-header { background: var(--tv-navy) !important; }
        .menu-block  { background: var(--tv-navy) !important; }
        .logo-block h3, .navbar-brand span { color: var(--tv-gold) !important; }
        .menubar > li.active > a,
        .menubar > li > a:hover { color: var(--tv-gold) !important; }
        footer.footer-main { background: var(--tv-navy) !important; }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body data-offset="200" data-spy="scroll" data-target=".ow-navigation">

    <!-- Page Loader -->
    <div id="site-loader" class="load-complete">
        <div class="loader">
            <div class="loader-inner ball-clip-rotate"><div></div></div>
        </div>
    </div>

    <!-- ===================== HEADER ===================== -->
    <header class="header-main container-fluid no-padding">

        <!-- Top strip: social + logo -->
        <div class="top-header container-fluid no-padding">
            <div class="container">
                <div class="row">
                    <div class="col-md-4 col-sm-4 col-xs-6 social">
                        <ul>
                            <li><a title="Facebook" href="#"><i class="fa fa-facebook"></i></a></li>
                            <li><a title="Twitter"  href="#"><i class="fa fa-twitter"></i></a></li>
                            <li><a title="Instagram" href="#"><i class="fa fa-instagram"></i></a></li>
                        </ul>
                    </div>
                    <div class="col-md-4 col-sm-4 col-xs-6 register">
                        <a href="mailto:info@thevenue.com" title="Contact">info@thevenue.com</a>
                    </div>
                    <div class="col-md-4 col-sm-4 col-xs-12 logo-block">
                        <a asp-controller="Home" asp-action="Index" title="THEVENUE">
                            <h3 style="color:var(--tv-gold);font-size:22px;letter-spacing:3px;">THEVENUE</h3>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <div class="menu-block container-fluid no-padding">
            <div class="container">
                <div class="col-md-12 col-sm-12">
                    <nav class="navbar ow-navigation">
                        <div class="navbar-header">
                            <button aria-controls="navbar" aria-expanded="false"
                                    data-target="#main-navbar" data-toggle="collapse"
                                    class="navbar-toggle collapsed" type="button">
                                <span class="sr-only">Toggle navigation</span>
                                <span class="icon-bar"></span>
                                <span class="icon-bar"></span>
                                <span class="icon-bar"></span>
                            </button>
                            <a asp-controller="Home" asp-action="Index" class="navbar-brand">
                                <span>THEVENUE</span>
                            </a>
                        </div>
                        <div class="navbar-collapse collapse" id="main-navbar">
                            <ul class="nav navbar-nav menubar">
                                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                                    <a asp-controller="Home" asp-action="Index" title="Home">Home</a>
                                </li>
                                <li>
                                    <a href="#venues-section" title="Our Venues">Our Venues</a>
                                </li>
                                <li>
                                    <a href="#events-section" title="Events">Events</a>
                                </li>
                                <li>
                                    <a href="#contact-section" title="Contact">Contact</a>
                                </li>
                            </ul>
                        </div>
                    </nav>
                </div>
            </div>
        </div>

    </header>
    <!-- ===================== /HEADER ===================== -->

    <!-- ===================== PAGE CONTENT ===================== -->
    @RenderBody()
    <!-- ===================== /PAGE CONTENT ===================== -->

    <!-- ===================== FOOTER ===================== -->
    <footer class="footer-main container-fluid no-padding" id="contact-section">
        <div class="container">

            <div class="footer-about">
                <div class="logo-block">
                    <h3 style="color:var(--tv-gold);font-size:24px;letter-spacing:4px;">THEVENUE</h3>
                </div>
                <div class="footer-about-content">
                    <h3 class="block-title">About THEVENUE</h3>
                    <p>We provide exceptional event spaces for every occasion — from intimate gatherings to grand galas. Let us be the backdrop to your most memorable moments.</p>
                </div>
            </div>

            <div class="row">
                <aside class="col-md-3 col-sm-6 col-xs-6 widget widget_customer_services">
                    <h3 class="block-title">Our Spaces</h3>
                    <ul>
                        <li><a href="#" title="Ballrooms">Ballrooms</a></li>
                        <li><a href="#" title="Rooftop Terraces">Rooftop Terraces</a></li>
                        <li><a href="#" title="Studio Lofts">Studio Lofts</a></li>
                        <li><a href="#" title="Conference Rooms">Conference Rooms</a></li>
                        <li><a href="#" title="Garden Venues">Garden Venues</a></li>
                    </ul>
                </aside>

                <aside class="col-md-2 col-sm-6 col-xs-6 widget widget_quick_links">
                    <h3 class="block-title">Quick Links</h3>
                    <ul>
                        <li><a asp-controller="Home" asp-action="Index" title="Home">Home</a></li>
                        <li><a href="#venues-section" title="Venues">Venues</a></li>
                        <li><a href="#events-section" title="Events">Events</a></li>
                        <li><a href="#contact-section" title="Contact">Contact</a></li>
                    </ul>
                </aside>

                <aside class="col-md-3 col-sm-6 col-xs-6 widget widget_contactus">
                    <h3 class="block-title">Contact Us</h3>
                    <div class="contactinfo-box">
                        <i class="fa fa-map-marker"></i>
                        <p>İstanbul, Turkey</p>
                    </div>
                    <div class="contactinfo-box">
                        <i class="fa fa-phone"></i>
                        <p><a href="tel:+902121234567">+90 212 123 45 67</a></p>
                    </div>
                    <div class="contactinfo-box">
                        <i class="fa fa-envelope"></i>
                        <p><a href="mailto:info@thevenue.com">info@thevenue.com</a></p>
                    </div>
                </aside>

                <aside class="col-md-4 col-sm-6 col-xs-6 widget widget_newsletter">
                    <h3 class="block-title">Stay Updated</h3>
                    <p>Subscribe to hear about upcoming events and new venue openings.</p>
                    <div class="input-group">
                        <input type="email" placeholder="Your email address" class="form-control">
                        <span class="input-group-btn">
                            <button type="button" class="btn">Go</button>
                        </span>
                    </div>
                    <ul style="margin-top:15px;">
                        <li><a href="#" title="Facebook"><i class="fa fa-facebook"></i></a></li>
                        <li><a href="#" title="Twitter"><i class="fa fa-twitter"></i></a></li>
                        <li><a href="#" title="Instagram"><i class="fa fa-instagram"></i></a></li>
                        <li><a href="#" title="LinkedIn"><i class="fa fa-linkedin"></i></a></li>
                    </ul>
                </aside>
            </div>
        </div>

        <div class="container">
            <div class="footer-menu">
                <div class="copyrights ow-pull-left">
                    <p>&copy; @DateTime.Now.Year THEVENUE &mdash; All rights reserved.</p>
                </div>
                <nav class="navbar ow-navigation ow-pull-right">
                    <div class="navbar-collapse collapse">
                        <ul class="nav navbar-nav">
                            <li><a asp-controller="Home" asp-action="Index" title="Home">Home</a></li>
                            <li><a href="#venues-section">Venues</a></li>
                            <li><a href="#events-section">Events</a></li>
                            <li><a href="#contact-section">Contact</a></li>
                        </ul>
                    </div>
                </nav>
            </div>
        </div>
    </footer>
    <!-- ===================== /FOOTER ===================== -->

    <!-- JS: jQuery first, then Bootstrap, then Mitri plugins -->
    <script src="~/lib-public/js/jquery.min.js"></script>
    <script src="~/lib-public/libraries/lib.js"></script>
    <script src="~/lib-public/libraries/jquery.countdown.min.js"></script>
    <script src="~/lib-public/libraries/lightslider-master/lightslider.js"></script>
    <script src="~/lib-public/js/functions.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
