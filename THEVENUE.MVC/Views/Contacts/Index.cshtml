@model IEnumerable<THEVENUE.MVC.Models.Contact>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Inbox";
}

@section DataTablesStyles {
    <link rel="stylesheet" type="text/css" href="~/lib-admin/js/plugins/datatables/media/css/dataTables.bootstrap.css">
}

<div class="row">
    <div class="col-md-12">
        <div class="panel">
            <div class="panel-heading" style="background:var(--tv-navy);border:none;">
                <h4 style="margin:0;color:#fff;font-size:14px;text-transform:uppercase;letter-spacing:1px;">
                    <i class="fa fa-envelope" style="color:var(--tv-gold);margin-right:8px;"></i>
                    Message Inbox
                </h4>
            </div>
            <div class="panel-body">
                <table id="contacts-table" class="table table-bordered table-hover" style="width:100%;">
                    <thead>
                        <tr style="background:var(--tv-cream);">
                            <th>#</th>
                            <th>Sender</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Subject</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th style="width:100px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var msg in Model)
                        {
                            <tr style="@(msg.IsRead ? "" : "font-weight: 600; background: rgba(201, 169, 110, 0.03);")">
                                <td>@msg.ContactId</td>
                                <td>@msg.Name</td>
                                <td>@msg.Email</td>
                                <td>@(string.IsNullOrEmpty(msg.Phone) ? "-" : msg.Phone)</td>
                                <td>@(string.IsNullOrEmpty(msg.Subject) ? "(No Subject)" : msg.Subject)</td>
                                <td>@msg.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                                <td>
                                    @if (msg.IsRead)
                                    {
                                        <span class="badge-confirmed">Read</span>
                                    }
                                    else
                                    {
                                        <span class="badge-pending" style="font-weight: 700;">Unread</span>
                                    }
                                </td>
                                <td>
                                    <a asp-controller="Contacts" asp-action="Details" asp-route-id="@msg.ContactId"
                                       class="btn btn-xs btn-info" title="Read Message">
                                        <i class="fa fa-eye"></i>
                                    </a>
                                    <form asp-controller="Contacts" asp-action="Delete" asp-route-id="@msg.ContactId"
                                          method="post" style="display:inline;"
                                          onsubmit="return confirm('Are you sure you want to delete this message?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-xs btn-danger" title="Delete">
                                            <i class="fa fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section DataTablesScripts {
    <script src="~/lib-admin/js/plugins/datatables/media/js/jquery.dataTables.js"></script>
    <script src="~/lib-admin/js/plugins/datatables/media/js/dataTables.bootstrap.js"></script>
    <script>
        $(function () {
            $('#contacts-table').DataTable({
                pageLength: 5,
                lengthMenu: [5, 10, 15, 20],
                stateSave: true,
                order: [[0, 'desc']],
                dom: '<"row"<"col-sm-6"l><"col-sm-6"f>>rt<"row"<"col-sm-6"i><"col-sm-6"p>>',
                language: { search: '<i class="fa fa-search"></i>', searchPlaceholder: 'Search messages...' }
            });
        });
    </script>
}
