<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - THEVENUE Admin</title>

    <!-- Micro Office: core CSS stack -->
    <link rel="stylesheet" type="text/css" href="~/lib-admin/skin/css/angular-material.min.css">
    <link rel="stylesheet" type="text/css" href="~/lib-admin/fonts/icomoon/icomoon.css">
    <link rel="stylesheet" type="text/css" href="~/lib-admin/fonts/animatedsvgicons/css/codropsicons.css">
    <link rel="stylesheet" type="text/css" href="~/lib-admin/js/plugins/magnific/magnific-popup.css">
    <link rel="stylesheet" type="text/css" href="~/lib-admin/js/plugins/c3charts/c3.min.css">
    <link rel="stylesheet" type="text/css" href="~/lib-admin/allcp/forms/css/forms.css">
    <link rel="stylesheet" type="text/css" href="~/lib-admin/js/utility/malihu-custom-scrollbar-plugin-master/jquery.mCustomScrollbar.min.css">
    <link rel="stylesheet" type="text/css" href="~/lib-admin/skin/default_skin/less/theme.css">

    <!-- DataTables (only loaded when a page needs it) -->
    @await RenderSectionAsync("DataTablesStyles", required: false)

    <!-- THEVENUE Admin brand overrides: Modern & Elite Redesign -->
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');
        
        body {
            font-family: 'Outfit', sans-serif !important;
            background-color: #fbf9f6 !important;
        }

        :root {
            --tv-gold:  #c9a96e;
            --tv-gold-hover: #dfbe84;
            --tv-navy:  #10101d; /* Deep rich elite navy */
            --tv-sidebar-bg: #1a1a2e;
            --tv-card-bg: #ffffff;
            --tv-cream: #fbf9f6;
            --tv-text-muted: #8e8ea0;
        }
        
        /* Modernized Topbar - Expanded all the way to the left */
        header.navbar.navbar-fixed-top {
            background: var(--tv-navy) !important;
            border-bottom: 1px solid rgba(201, 169, 110, 0.15) !important;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.15) !important;
            backdrop-filter: blur(8px);
            height: 60px !important;
            padding-right: 25px !important;
            padding-left: 0 !important;
            left: 0 !important;
            width: 100% !important;
            margin: 0 !important;
            z-index: 1050 !important;
        }

        /* Sidebar Toggle Button alignment */
        .navbar-left, .navbar-left li {
            height: 60px !important;
            display: flex !important;
            align-items: center !important;
        }
        .navbar-left .navbar-btn {
            margin: 0 !important;
            padding: 0 10px !important;
            height: 60px !important;
            display: flex !important;
            align-items: center !important;
        }
        #sidebar_left_toggle {
            height: 40px !important;
            width: 40px !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            background: transparent !important;
            border: none !important;
            color: #fff !important;
            padding: 0 !important;
            margin: 0 !important;
            border-radius: 50% !important;
            transition: all 0.3s ease;
        }
        #sidebar_left_toggle:hover {
            background-color: rgba(255, 255, 255, 0.08) !important;
            color: var(--tv-gold) !important;
        }

        .navbar-branding {
            background-color: var(--tv-navy) !important;
            width: 230px !important;
            height: 60px !important;
            position: absolute !important;
            left: 0 !important;
            top: 0 !important;
            display: flex !important;
            align-items: center !important;
            padding-left: 20px !important;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
            transition: all 0.3s ease !important;
            overflow: hidden !important;
            z-index: 1060 !important;
        }

        body.sb-l-m .navbar-branding {
            width: 60px !important;
            padding-left: 0 !important;
            justify-content: center !important;
        }

        body.sb-l-m .navbar-branding .brand-text {
            display: none !important;
        }

        body.sb-l-m .navbar-branding .brand-icon {
            margin: 0 !important;
            font-size: 22px !important;
        }

        .navbar-left {
            margin-left: 230px !important;
            transition: all 0.3s ease !important;
            height: 60px !important;
            display: flex !important;
            align-items: center !important;
        }

        body.sb-l-m .navbar-left {
            margin-left: 60px !important;
        }

        .navbar-right {
            display: flex !important;
            align-items: center !important;
            justify-content: flex-end !important;
            height: 60px !important;
            margin: 0 !important;
            padding-right: 25px !important;
            gap: 15px !important;
            position: absolute !important;
            right: 0 !important;
            top: 0 !important;
        }

        .navbar-right li {
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            height: 100% !important;
            margin: 0 !important;
        }

        .navbar-right li > a {
            width: 40px !important;
            height: 40px !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            padding: 0 !important;
            margin: 0 !important;
            border-radius: 50% !important;
            color: var(--tv-gold) !important;
            transition: all 0.3s ease !important;
        }

        .navbar-right li > a:hover {
            background-color: rgba(255, 255, 255, 0.08) !important;
        }

        .navbar-right li > a span {
            color: var(--tv-gold) !important;
            font-size: 18px !important;
        }
        /* Prevent user dropdown icon from being overridden by chevron caret */
        .navbar-right .navbar-profile-custom a.dropdown-toggle span.fa-user::before,
        .navbar-right .navbar-profile-custom a.dropdown-toggle span.fa-user:before {
            content: "\f007" !important;
        }
        .navbar .nav > li.dropdown.navbar-profile-custom > a.dropdown-toggle > .fa {
            font-size: 18px !important;
            position: static !important;
            margin: 0 !important;
            color: var(--tv-gold) !important;
        }
        
        .navbar-brand-custom {
            font-family: 'Outfit', sans-serif;
            color: var(--tv-gold) !important;
            font-size: 18px;
            font-weight: 700;
            letter-spacing: 3px;
            text-transform: uppercase;
            line-height: 60px;
            text-decoration: none !important;
            transition: all 0.3s ease;
        }
        
        .navbar-brand-custom:hover {
            color: var(--tv-gold-hover) !important;
            text-shadow: 0 0 10px rgba(201, 169, 110, 0.3);
        }

        /* Modernized Sidebar */
        #sidebar_left {
            background: var(--tv-sidebar-bg) !important;
            border-right: 1px solid rgba(201, 169, 110, 0.08) !important;
            box-shadow: 4px 0 30px rgba(0, 0, 0, 0.05);
            top: 60px !important;
        }

        /* Collapsed Sidebar Menu Icons & highlights alignment - Centered between screen edge and sidebar edge */
        body.sb-l-m #sidebar_left,
        body.sb-l-m .sidebar-left-content,
        body.sb-l-m .sidebar-menu {
            width: 60px !important;
            padding: 0 !important;
            margin: 0 !important;
        }
        body.sb-l-m .sidebar-menu > li {
            width: 60px !important;
            padding: 0 !important;
            margin: 0 auto 4px auto !important;
            list-style: none !important;
            display: flex !important;
            justify-content: center !important;
            align-items: center !important;
        }
        body.sb-l-m .sidebar-menu > li > a {
            padding: 0 !important;
            margin: 0 !important;
            width: 60px !important;
            height: 60px !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            background: transparent !important;
        }
        body.sb-l-m .sidebar-menu > li > a .sb-menu-icon {
            position: static !important;
            left: auto !important;
            right: auto !important;
            top: auto !important;
            margin: 0 !important;
            font-size: 18px !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            width: 40px !important;
            height: 40px !important;
            border-radius: 8px !important;
            transition: all 0.3s ease !important;
        }

        /* Active Item highlight rules in collapsed sidebar */
        body.sb-l-m .sidebar-menu li.active > a {
            background: transparent !important;
            box-shadow: none !important;
        }

        body.sb-l-m .sidebar-menu li.active > a .sb-menu-icon {
            background: var(--tv-gold) !important;
            color: var(--tv-navy) !important;
            box-shadow: 0 4px 12px rgba(201, 169, 110, 0.35) !important;
        }

        /* Top Left Hamburger Button Override */
        .navbar-left .navbar-btn,
        .navbar-left #sidebar_left_toggle,
        .navbar-left #sidebar-left-toggle {
            background: transparent !important;
            border: none !important;
            box-shadow: none !important;
            color: #fff !important;
        }
        .navbar-left #sidebar_left_toggle:hover,
        .navbar-left #sidebar-left-toggle:hover {
            color: var(--tv-gold) !important;
        }

        /* User Dropdown Menu Hover Styles */
        .dropdown-menu > li > a:hover {
            background-color: rgba(201, 169, 110, 0.1) !important;
            color: var(--tv-gold) !important;
        }
        
        .sidebar-menu {
            padding: 15px 10px !important;
        }
        
        .sidebar-menu li.sidebar-label {
            color: var(--tv-text-muted) !important;
            font-size: 11px !important;
            text-transform: uppercase !important;
            letter-spacing: 2px !important;
            font-weight: 600 !important;
            padding: 25px 15px 8px 15px !important;
        }
        
        .sidebar-menu li > a {
            color: #b0b0c5 !important;
            font-size: 14px !important;
            font-weight: 400 !important;
            padding: 12px 18px !important;
            border-radius: 8px !important;
            margin-bottom: 4px !important;
            transition: all 0.3s ease !important;
            border-left: none !important;
            display: flex !important;
            align-items: center;
            justify-content: flex-start;
            position: relative;
        }
        
        .sidebar-menu li > a:hover {
            color: var(--tv-gold) !important;
            background: rgba(201, 169, 110, 0.06) !important;
            padding-left: 22px !important;
        }
        
        .sidebar-menu li.active > a {
            color: var(--tv-navy) !important;
            background: var(--tv-gold) !important;
            font-weight: 600 !important;
            box-shadow: 0 4px 15px rgba(201, 169, 110, 0.3) !important;
        }
        
        .sidebar-menu li.active > a .sb-menu-icon {
            color: var(--tv-navy) !important;
        }
        
        .sb-menu-icon {
            font-size: 16px !important;
            color: #b0b0c5 !important;
            margin-right: 12px;
            transition: all 0.3s ease;
            width: 20px;
            text-align: center;
        }
        
        .sidebar-menu li > a:hover .sb-menu-icon {
            color: var(--tv-gold) !important;
            transform: scale(1.1);
        }

        /* Message dot topbar */
        .topbar-msg-btn {
            position: relative;
        }
        .msg-badge {
            position: absolute;
            top: 15px;
            right: 10px;
            background: #d9534f;
            border-radius: 50%;
            width: 8px;
            height: 8px;
            border: 1px solid var(--tv-navy);
            display: none; /* hidden until unread count > 0 */
        }
        
        /* TempData success toast */
        .tv-toast { position:fixed; top:75px; right:20px; z-index:9999; min-width:280px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); border-radius: 6px; }
        
        /* Badges */
        .badge-pending {
            background: rgba(240, 173, 78, 0.15) !important;
            color: #f0ad4e !important;
            border: 1px solid rgba(240, 173, 78, 0.3);
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            display: inline-block;
        }
        .badge-confirmed {
            background: rgba(92, 184, 92, 0.15) !important;
            color: #5cb85c !important;
            border: 1px solid rgba(92, 184, 92, 0.3);
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            display: inline-block;
        }
        .badge-cancelled {
            background: rgba(217, 83, 79, 0.15) !important;
            color: #d9534f !important;
            border: 1px solid rgba(217, 83, 79, 0.3);
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            display: inline-block;
        }
        
        /* Breadcrumbs and Topbar Alt Header */
        #topbar.alt {
            background: transparent !important;
            border-bottom: none !important;
            padding: 20px 25px 5px !important;
        }
        
        .breadcrumb {
            background: transparent !important;
            padding: 0 !important;
            font-size: 13px;
        }
        
        .breadcrumb a {
            color: var(--tv-gold) !important;
            text-decoration: none;
        }
        
        .breadcrumb-current-item {
            color: var(--tv-navy) !important;
            font-weight: 500;
        }
        
        /* Table / Panel Customizations */
        .panel {
            background: #fff;
            border-radius: 12px !important;
            box-shadow: 0 4px 25px rgba(0, 0, 0, 0.03) !important;
            border: 1px solid rgba(0,0,0,0.04) !important;
            overflow: hidden;
            margin-bottom: 25px;
        }
        
        .panel-heading {
            background: var(--tv-navy) !important;
            padding: 16px 20px !important;
            border-bottom: 1px solid rgba(201, 169, 110, 0.1) !important;
        }
        
        .panel-heading h4 {
            color: #ffffff !important;
            font-weight: 600 !important;
            font-size: 14px !important;
            letter-spacing: 1px;
        }
        
        .panel-body {
            padding: 20px !important;
        }
        
        .table {
            margin-bottom: 0 !important;
        }
        
        .table > thead > tr > th {
            font-weight: 600 !important;
            text-transform: uppercase;
            font-size: 11px;
            letter-spacing: 1px;
            border-bottom: 1px solid #eee !important;
            color: #555;
            padding: 12px 10px !important;
        }
        
        .table > tbody > tr > td {
            font-size: 14px;
            color: #444;
            padding: 14px 10px !important;
            border-top: 1px solid #f3f3f3 !important;
            vertical-align: middle !important;
        }
        
        /* KPI Cards custom */
        .kpi-card {
            border-top: none !important;
            border-left: 4px solid var(--tv-gold) !important;
            transition: all 0.3s ease;
        }
        .kpi-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06) !important;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="dashboard-page sb-l-o sb-r-c">
<div id="main">

    <!-- ===================== TOP NAVBAR ===================== -->
    <header class="navbar navbar-fixed-top">
    
        <div class="navbar-branding">
            <a asp-controller="Dashboard" asp-action="Index" class="navbar-brand-custom" style="display: flex; align-items: center; gap: 10px; font-family:'Outfit', sans-serif; font-size:18px; letter-spacing:2px; font-weight:700; text-decoration:none;">
                <span class="fa fa-star brand-icon"></span>
                <span class="brand-text"><span style="color:#fff; font-weight:300;">THE</span><span style="color:var(--tv-gold); font-weight:700;">VENUE</span></span>
            </a>
        </div>

        <ul class="nav navbar-nav navbar-left">
            <li>
                <div class="navbar-btn btn-group phn">
                    <button class="btn-hover-effects btn sidebar-toggle" id="sidebar_left_toggle">
                        <span class="fa fa-bars fs18"></span>
                    </button>
                </div>
            </li>
        </ul>

        <ul class="nav navbar-nav navbar-right">
            
            <li>
                <a asp-controller="Contacts" asp-action="Index" class="topbar-msg-btn" title="Inbox">
                    <span class="fa fa-envelope fs18"></span>
                    <span class="msg-badge" id="unread-dot"></span>
                </a>
            </li>
            
            <li class="dropdown navbar-profile-custom">
                <a href="#" class="dropdown-toggle" data-toggle="dropdown">
                    <span class="fa fa-user fs18"></span>
                </a>
                <ul class="dropdown-menu dropdown-menu-right w180" role="menu" style="background-color:#10101d; border:1px solid rgba(201, 169, 110, 0.2); margin-top:10px; border-radius: 4px; box-shadow: 0 4px 15px rgba(0,0,0,0.2);">
                    <li style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                        <a href="#" style="color:#fff; padding:12px 18px; display:block; text-decoration:none; font-family:'Outfit', sans-serif; font-size:13px; font-weight:500;">
                            <span class="fa fa-cog" style="color:var(--tv-gold); margin-right:10px; width:15px; text-align:center;"></span>Settings
                        </a>
                    </li>
                    <li>
                        <a href="#" style="color:#fff; padding:12px 18px; display:block; text-decoration:none; font-family:'Outfit', sans-serif; font-size:13px; font-weight:500;">
                            <span class="fa fa-sign-out" style="color:var(--tv-gold); margin-right:10px; width:15px; text-align:center;"></span>Logout
                        </a>
                    </li>
                </ul>
            </li>
            
            <li>
                <a asp-controller="Home" asp-action="Index" title="View Public Site">
                    <span class="fa fa-external-link fs18"></span>
                </a>
            </li>
            
        </ul>
    </header>
    <!-- ===================== /TOP NAVBAR ===================== -->

    <!-- ===================== SIDEBAR ===================== -->
    <aside id="sidebar_left" class="nano affix">
        <div class="sidebar-left-content nano-content">

            <!-- Nav -->
            <ul class="nav sidebar-menu">

                <li class="sidebar-label pt20">Main</li>

                <!-- Dashboard -->
                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <a asp-controller="Dashboard" asp-action="Index">
                        <span class="sb-menu-icon fa fa-home"></span>
                        <span class="sidebar-title">Dashboard</span>
                    </a>
                </li>

                <li class="sidebar-label pt20">Management</li>

                <!-- Venues -->
                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Venues" ? "active" : "")">
                    <a asp-controller="Venues" asp-action="Index">
                        <span class="sb-menu-icon fa fa-building"></span>
                        <span class="sidebar-title">Venues</span>
                    </a>
                </li>

                <!-- Events -->
                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Events" ? "active" : "")">
                    <a asp-controller="Events" asp-action="Index">
                        <span class="sb-menu-icon fa fa-calendar"></span>
                        <span class="sidebar-title">Events</span>
                    </a>
                </li>

                <!-- Reservations -->
                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Reservations" ? "active" : "")">
                    <a asp-controller="Reservations" asp-action="Index">
                        <span class="sb-menu-icon fa fa-ticket"></span>
                        <span class="sidebar-title">Reservations</span>
                    </a>
                </li>

                <!-- Messages -->
                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Contacts" ? "active" : "")">
                    <a asp-controller="Contacts" asp-action="Index">
                        <span class="sb-menu-icon fa fa-envelope"></span>
                        <span class="sidebar-title">Messages</span>
                        <span class="badge" id="sidebar-msg-badge" style="display:none;background:#d9534f;color:#fff;font-weight:700;padding:3px 8px;border-radius:10px;margin-left:auto;font-size:10px;">0</span>
                    </a>
                </li>

            </ul>
        </div>
    </aside>
    <!-- ===================== /SIDEBAR ===================== -->

    <!-- ===================== CONTENT WRAPPER ===================== -->
    <section id="content_wrapper">

        <!-- Topbar breadcrumb -->
        <header id="topbar" class="alt">
            <div class="topbar-left">
                <ol class="breadcrumb">
                    <li class="breadcrumb-link">
                        <a asp-controller="Dashboard" asp-action="Index">Home</a>
                    </li>
                    <li class="breadcrumb-current-item">@ViewData["Title"]</li>
                </ol>
            </div>
            <div class="topbar-right" style="padding:12px 20px;">
                @await RenderSectionAsync("TopbarActions", required: false)
            </div>
        </header>

        <!-- Success / error toasts from TempData -->
        @if (TempData["Success"] != null)
        {
            <div class="tv-toast alert alert-success alert-dismissible fade in" role="alert">
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                <strong><i class="fa fa-check-circle"></i></strong> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="tv-toast alert alert-danger alert-dismissible fade in" role="alert">
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                <strong><i class="fa fa-times-circle"></i></strong> @TempData["Error"]
            </div>
        }

        <!-- Page Body -->
        <section id="content" class="table-layout animated fadeIn">
            <div class="chute chute-center">
                @RenderBody()
            </div>
        </section>

    </section>
    <!-- ===================== /CONTENT WRAPPER ===================== -->

</div><!-- /#main -->

<!-- ===================== JS ===================== -->
<script src="~/lib-admin/js/jquery/jquery-1.12.3.min.js"></script>
<script src="~/lib-admin/js/jquery/jquery_ui/jquery-ui.min.js"></script>
<script src="~/lib-admin/fonts/animatedsvgicons/js/snap.svg-min.js"></script>
<script src="~/lib-admin/fonts/animatedsvgicons/js/svgicons-config.js"></script>
<script src="~/lib-admin/fonts/animatedsvgicons/js/svgicons.js"></script>
<script src="~/lib-admin/fonts/animatedsvgicons/js/svgicons-init.js"></script>
<script src="~/lib-admin/js/utility/malihu-custom-scrollbar-plugin-master/jquery.mCustomScrollbar.concat.min.js"></script>
<script src="~/lib-admin/js/plugins/c3charts/d3.min.js"></script>
<script src="~/lib-admin/js/plugins/c3charts/c3.min.js"></script>
<script src="~/lib-admin/js/utility/utility.js"></script>
<script src="~/lib-admin/js/main.js"></script>

<!-- Sidebar toggle & Dynamic Badges wiring -->
<script>
    $(function () {
        // Init theme core features (scrollbars, side menu, etc.)
        Core.init();


        // Auto-dismiss toasts after 4s
        setTimeout(function () { $('.tv-toast').fadeOut(400); }, 4000);

        // Fetch unread messages count periodically
        function updateUnreadCount() {
            $.ajax({
                url: '/admin/contacts/unread-count',
                type: 'GET',
                cache: false,
                success: function (data) {
                    if (data && data.count > 0) {
                        $('#unread-dot').fadeIn();
                        $('#sidebar-msg-badge').text(data.count).fadeIn();
                    } else {
                        $('#unread-dot').fadeOut();
                        $('#sidebar-msg-badge').fadeOut();
                    }
                },
                error: function() {
                    // Ignore errors to avoid logging noise
                }
            });
        }

        // Run immediately on page load, and poll every 20s
        updateUnreadCount();
        setInterval(updateUnreadCount, 20000);
    });
</script>

@await RenderSectionAsync("DataTablesScripts", required: false)
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
